generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER @map("user")
  ADMIN @map("admin")
  SUPERADMIN @map("superadmin")
  CREATOR @map("creator")
  MEMBER @map("member")
  STAFF @map("staff")
}

enum SuperAdminSettingSection {
  REVENUE @map("revenue")
  COMPANY_INFO @map("company_info")
}

enum CreatorEventStatus {
  DRAFT @map("draft")
  SCHEDULED @map("scheduled")
  LIVE @map("live")
  ENDED @map("ended")
  CANCELLED @map("cancelled")
}

enum CreatorEventLocationType {
  COUNTRY @map("country")
  STATE @map("state")
  CITY @map("city")
  ADDRESS @map("address")
}

enum CreatorEventLocationRestrictionMode {
  BLOCK @map("block")
  ALLOW @map("allow")
}

enum CreatorEventTicketAccessType {
  STREAM @map("stream")
  VENUE @map("venue")
}

enum CreatorEventTicketStatus {
  ACTIVE @map("active")
  PAUSED @map("paused")
  SOLD_OUT @map("sold_out")
  ARCHIVED @map("archived")
}

enum CreatorEventTicketPurchaseStatus {
  PENDING @map("pending")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
  REFUNDED @map("refunded")
  FAILED @map("failed")
}

enum CreatorEventCheckInUserStatus {
  ACTIVE @map("active")
  INACTIVE @map("inactive")
}

enum CreatorEventCheckInScanStatus {
  SUCCESS @map("success")
  DUPLICATE @map("duplicate")
  INVALID @map("invalid")
  REJECTED @map("rejected")
}

enum CreatorEventRecordingStatus {
  DISABLED @map("disabled")
  PENDING @map("pending")
  RECORDING @map("recording")
  PROCESSING @map("processing")
  READY @map("ready")
  FAILED @map("failed")
}

model Profile {
  id            String   @id
  email         String   @unique
  role          Role     @default(USER)
  fullName      String?  @map("full_name")
  avatarUrl     String?  @map("avatar_url")
  bio           String?

  creator       Creator?

  addressFull   String? @map("address_full")
  addressLat    Float?  @map("address_lat")
  addressLon    Float?  @map("address_lon")
  addressType   String? @map("address_type")
  addressCountry String? @map("address_country")
  addressState  String? @map("address_state")
  addressName   String? @map("address_name")

  age           Int?
  sex           String?
  emailVerified Boolean  @default(false) @map("email_verified")
  hasPassword   Boolean  @default(false) @map("has_password")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  credential    AuthCredential?
  session       Session[]
  videoPurchases CreatorVideoPurchase[]

  @@map("profiles")
}

model SuperAdminSetting {
  id                     String                   @id
  section                SuperAdminSettingSection @unique

  platformFeePercentage  Int?    @map("platform_fee_percentage")
  enterpriseFeePercentage Int?    @map("enterprise_fee_percentage")
  minimumPayoutAmount    Int?    @map("minimum_payout_amount")
  payoutProcessingDays   Int?    @map("payout_processing_days")

  companyName            String? @map("company_name")
  companyEmail           String? @map("company_email")
  supportEmail           String? @map("support_email")
  companyPhone           String? @map("company_phone")
  companyAddress         String? @map("company_address")
  companyWebsite         String? @map("company_website")

  createdBy              String?                  @map("created_by")
  updatedBy              String?                  @map("updated_by")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")

  @@map("superadmin_settings")
}

model AuthCredential {
  email        String   @id
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile      Profile  @relation(fields: [email], references: [email], onDelete: Cascade)

  @@map("auth_credentials")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

// Creator profile created when agreement is accepted
model Creator {
  id        String   @id
  profile   Profile  @relation(fields: [profileId], references: [email], onDelete: Cascade)
  profileId String   @unique @map("profile_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  videos         CreatorVideo[]
  videoPurchases CreatorVideoPurchase[]
  folders        CreatorVideoFolder[]
  events         CreatorEvent[]
  checkInUsers   CreatorEventCheckInUser[]

  @@map("creators")
}


model CreatorVideoFolder {
  id            String   @id
  creatorId     String   @map("creator_id")
  creator       Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  title         String
  folderType    String   @map("folder_type")
  status        String   @default("active")

  thumbnailUrl    String? @map("thumbnail_url")
  thumbnailFileId String? @map("thumbnail_file_id")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  videos        CreatorVideo[]

  @@index([creatorId])
  @@map("creator_video_folders")
}

model CreatorVideo {
  id              String   @id
  creatorId       String   @map("creator_id")
  creator         Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  folderId        String   @map("folder_id")
  folder          CreatorVideoFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  category        String?

  videoUrl        String?  @map("video_url")
  videoFileId     String?  @map("video_file_id")
  thumbnailUrl    String?  @map("thumbnail_url")
  thumbnailFileId String?  @map("thumbnail_file_id")

  isPrivate       Boolean  @default(false) @map("is_private")
  isPremium       Boolean  @default(false) @map("is_premium")
  monetizationType String   @default("free") @map("monetization_type")

  status          String   @default("processing")
  publishNow      Boolean  @default(true) @map("publish_now")
  scheduledAt     DateTime? @map("scheduled_at")

  // monetization pricing
  // (UI supports: rent24Price, rent48Price, purchasePrice)
  rent24Price     Int?    @map("rent24_price")
  rent48Price     Int?    @map("rent48_price")
  purchasePrice   Int?    @map("purchase_price")

  // used by current UI for series support
  tags            String[] @default([])
  packageName     String? @map("package_name")
  episodeIndex    Int?    @map("episode_index")

  // duration from upload provider (e.g. "12:34")
  duration        String? @map("duration")

  // content settings

  allowComments   Boolean  @default(true) @map("allow_comments")
  ageRestriction  Boolean  @default(false) @map("age_restriction")

  // counters relationships
  views           CreatorVideoView[]
  likes           CreatorVideoLike[]
  comments        CreatorVideoComment[]
  purchases       CreatorVideoPurchase[]

  // analytics & revenue tracking
  viewsCount      Int      @default(0) @map("views_count")
  likesCount      Int      @default(0) @map("likes_count")
  commentsCount   Int      @default(0) @map("comments_count")
  revenue         Int      @default(0) // revenue in cents

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([creatorId])
  @@index([folderId])
  @@map("creator_videos")
}

model CreatorVideoPurchase {
  id              String   @id
  creatorId       String   @map("creator_id")
  creator         Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  creatorVideoId  String   @map("creator_video_id")
  creatorVideo    CreatorVideo @relation(fields: [creatorVideoId], references: [id], onDelete: Cascade)

  buyerProfileId  String?  @map("buyer_profile_id")
  buyerProfile    Profile? @relation(fields: [buyerProfileId], references: [id], onDelete: SetNull)

  buyerName       String?  @map("buyer_name")
  buyerEmail      String?  @map("buyer_email")
  buyerPhone      String?  @map("buyer_phone")
  purchaseType    String   @map("purchase_type")
  accessCode      String   @unique @map("access_code")

  amount          Int
  currency        String   @default("NGN")
  status          String   @default("PENDING")
  transactionId   String   @unique @map("transaction_id")
  accessExpiresAt DateTime? @map("access_expires_at")
  purchasedAt     DateTime @default(now()) @map("purchased_at")
  completedAt     DateTime? @map("completed_at")

  @@index([creatorId])
  @@index([creatorVideoId])
  @@index([buyerProfileId])
  @@index([buyerEmail])
  @@index([status])
  @@map("creator_video_purchases")
}

model CreatorVideoView {
  id              String   @id
  creatorVideoId String   @map("creator_video_id")
  creatorVideo   CreatorVideo @relation(fields: [creatorVideoId], references: [id], onDelete: Cascade)

  viewerProfileId String? @map("viewer_profile_id")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([creatorVideoId])
  @@map("creator_video_views")
}

model CreatorVideoLike {
  id              String   @id
  creatorVideoId String   @map("creator_video_id")
  creatorVideo   CreatorVideo @relation(fields: [creatorVideoId], references: [id], onDelete: Cascade)

  likerProfileId  String? @map("liker_profile_id")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([creatorVideoId])
  @@map("creator_video_likes")
}

model CreatorVideoComment {
  id              String   @id
  creatorVideoId String   @map("creator_video_id")
  creatorVideo   CreatorVideo @relation(fields: [creatorVideoId], references: [id], onDelete: Cascade)

  commenterProfileId String? @map("commenter_profile_id")
  content            String

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([creatorVideoId])
  @@map("creator_video_comments")
}




model CreatorEvent {
  id           String   @id
  creatorId String   @map("creator_id")
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  title       String
  description String?
  category    String   @default("music")
  status      CreatorEventStatus @default(SCHEDULED)

  isPrivate                 Boolean @default(false) @map("is_private")
  isPaid                    Boolean @default(false) @map("is_paid")
  requireTicket             Boolean @default(false) @map("require_ticket")
  enableDonations           Boolean @default(false) @map("enable_donations")
  enableLocationRestriction Boolean @default(false) @map("enable_location_restriction")
  locationRestrictionType    CreatorEventLocationRestrictionMode @default(BLOCK) @map("location_restriction_type")

  address             String? @map("address")
  locationName        String? @map("location_name")
  locationCountry     String? @map("location_country")
  locationState       String? @map("location_state")
  locationType        CreatorEventLocationType? @map("location_type")
  locationLat         Float?  @map("location_lat")
  locationLon         Float?  @map("location_lon")
  locationFullAddress String? @map("location_full_address")

  thumbnailUrl         String? @map("thumbnail_url")
  thumbnailFileId      String? @map("thumbnail_file_id")
  thumbnailVideoUrl    String? @map("thumbnail_video_url")
  thumbnailVideoFileId String? @map("thumbnail_video_file_id")
  recordedVideoUrl     String? @map("recorded_video_url")
  recordedVideoFileId  String? @map("recorded_video_file_id")

  streamKey String? @unique @map("stream_key")
  rtmpUrl   String? @map("rtmp_url")
  ingressId String? @unique @map("ingress_id")

  livekitRoomName String? @unique @map("livekit_room_name")

  recordingEnabled Boolean @default(false) @map("recording_enabled")
  recordingStatus  CreatorEventRecordingStatus @default(DISABLED) @map("recording_status")
  recordingAssetId  String? @unique @map("recording_asset_id")
  recordingUrl      String? @map("recording_url")
  recordingFileId   String? @map("recording_file_id")
  recordingStartedAt DateTime? @map("recording_started_at")
  recordingEndedAt   DateTime? @map("recording_ended_at")

  hasRecordedVideo Boolean @default(false) @map("has_recorded_video")
  timezone         String  @default("Africa/Lagos")
  scheduledAt      DateTime? @map("scheduled_at")
  startedAt        DateTime? @map("started_at")
  endedAt          DateTime? @map("ended_at")
  durationMinutes  Int     @default(60) @map("duration_minutes")
  maxViewers       Int?    @map("max_viewers")
  estimatedUsers   Int?    @map("estimated_users")

  tags String[] @default([])

  viewsCount           Int @default(0) @map("views_count")
  likesCount           Int @default(0) @map("likes_count")
  commentsCount        Int @default(0) @map("comments_count")
  peakViewersCount     Int @default(0) @map("peak_viewers_count")
  currentViewersCount  Int @default(0) @map("current_viewers_count")
  venueParticipantCount Int @default(0) @map("venue_participant_count")
  revenue              Int @default(0)

  restrictedLocations CreatorEventLocationRestriction[]
  tickets             CreatorEventTicket[]
  checkInUsers        CreatorEventCheckInUser[]
  checkInScans        CreatorEventCheckInScan[]
  CheckInCameraSessions CreatorEventCheckInCameraSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([creatorId])
  @@index([status])
  @@index([scheduledAt])
  @@map("creator_events")
}

model CreatorEventLocationRestriction {
  id           String   @id
  eventId String       @map("event_id")
  event   CreatorEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name         String
  country      String
  state        String?
  lat          Float?
  lon          Float?
  locationType CreatorEventLocationType @map("location_type")
  fullAddress  String? @map("full_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("creator_event_location_restrictions")
}

model CreatorEventTicket {
  id           String   @id
  eventId String       @map("event_id")
  event   CreatorEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  ticketType  String @map("ticket_type")
  access      CreatorEventTicketAccessType @default(STREAM)
  price       Int    @default(0)
  quantity    Int    @default(0)
  soldCount   Int    @default(0) @map("sold_count")
  revenue     Int    @default(0)
  description String?
  benefits    String[] @default([])
  status      CreatorEventTicketStatus @default(ACTIVE)

  purchases CreatorEventTicketPurchase[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([eventId, ticketType])
  @@index([eventId])
  @@index([status])
  @@map("creator_event_tickets")
}

model CreatorEventTicketPurchase {
  id           String   @id
  ticketId String   @map("ticket_id")
  ticket   CreatorEventTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  buyerName  String @map("buyer_name")
  buyerEmail String @map("buyer_email")
  buyerPhone String? @map("buyer_phone")
  quantity   Int    @default(1)

  amount        Int
  currency      String @default("NGN")
  status        CreatorEventTicketPurchaseStatus @default(COMPLETED)
  transactionId String @unique @map("transaction_id")
  ticketCode    String @unique @map("ticket_code")

  purchasedAt DateTime @default(now()) @map("purchased_at")
  refundedAt  DateTime? @map("refunded_at")
  checkedInAt DateTime? @map("checked_in_at")
  checkedInByUserId String? @map("checked_in_by_user_id")
  checkedInByUser CreatorEventCheckInUser? @relation(fields: [checkedInByUserId], references: [id], onDelete: SetNull)

  scans CreatorEventCheckInScan[]

  @@index([ticketId])
  @@index([buyerEmail])
  @@index([status])
  @@map("creator_event_ticket_purchases")
}

model CreatorEventCheckInUser {
  id        String   @id
  creatorId String   @map("creator_id")
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  eventId   String   @map("event_id")
  event     CreatorEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  fullName  String @map("full_name")
  email     String @unique
  username  String @unique
  passwordHash String @map("password_hash")
  tempPasswordHash String? @map("temp_password_hash")
  gateName  String @map("gate_name")
  status    CreatorEventCheckInUserStatus @default(ACTIVE)
  mustChangePassword Boolean @default(true) @map("must_change_password")

  scansToday Int @default(0) @map("scans_today")
  totalScans Int @default(0) @map("total_scans")
  lastLoginAt DateTime? @map("last_login_at")
  lastScanAt  DateTime? @map("last_scan_at")

  checkedInPurchases CreatorEventTicketPurchase[]
  scans CreatorEventCheckInScan[]
  cameraSessions CreatorEventCheckInCameraSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([creatorId])
  @@index([eventId])
  @@index([status])
  @@map("creator_event_check_in_users")
}

model CreatorEventCheckInCameraSession {
  id            String   @id
  tokenHash     String   @unique @map("token_hash")
  tokenPrefix   String   @map("token_prefix")
  eventId       String   @map("event_id")
  event         CreatorEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  operatorUserId String @map("operator_user_id")
  operatorUser   CreatorEventCheckInUser @relation(fields: [operatorUserId], references: [id], onDelete: Cascade)

  status        String   @default("ACTIVE")
  expiresAt     DateTime @map("expires_at")
  openedAt      DateTime? @map("opened_at")
  connectedAt   DateTime? @map("connected_at")
  completedAt   DateTime? @map("completed_at")
  revokedAt     DateTime? @map("revoked_at")
  lastSeenAt    DateTime? @map("last_seen_at")
  clientLabel   String?  @map("client_label")

  signals       CreatorEventCheckInCameraSignal[]
  audits        CreatorEventCheckInCameraAudit[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([eventId])
  @@index([operatorUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("creator_event_check_in_camera_sessions")
}

model CreatorEventCheckInCameraSignal {
  id         String   @id
  sessionId  String   @map("session_id")
  session    CreatorEventCheckInCameraSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sender     String
  type       String
  payload    String

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("creator_event_check_in_camera_signals")
}

model CreatorEventCheckInCameraAudit {
  id        String   @id
  sessionId String?  @map("session_id")
  session   CreatorEventCheckInCameraSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  actor     String
  action    String
  message   String?
  metadata  String?  @map("metadata")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([actor])
  @@index([action])
  @@map("creator_event_check_in_camera_audits")
}

model CreatorEventCheckInScan {
  id      String   @id
  eventId String   @map("event_id")
  event   CreatorEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  checkInUserId String? @map("check_in_user_id")
  checkInUser   CreatorEventCheckInUser? @relation(fields: [checkInUserId], references: [id], onDelete: SetNull)

  ticketPurchaseId String? @map("ticket_purchase_id")
  ticketPurchase   CreatorEventTicketPurchase? @relation(fields: [ticketPurchaseId], references: [id], onDelete: SetNull)

  attendeeName  String? @map("attendee_name")
  attendeeEmail String? @map("attendee_email")
  gateName      String? @map("gate_name")
  scannedCode   String? @unique @map("scanned_code")
  status        CreatorEventCheckInScanStatus @default(SUCCESS)
  notes         String?
  scannedAt     DateTime @default(now()) @map("scanned_at")

  @@index([eventId])
  @@index([checkInUserId])
  @@index([ticketPurchaseId])
  @@index([status])
  @@map("creator_event_check_in_scans")
}

model Session {
  id           String   @id
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
 profile      Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
